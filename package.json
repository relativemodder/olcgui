{
	"name": "olcgui",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "API_BACKEND_URL=http://localhost:3001 sh -c 'bun --bun src/server/api.ts & api_pid=$!; trap \"kill $api_pid 2>/dev/null\" EXIT INT TERM; bun --bun vite dev'",
		"dev:container": "HOST=0.0.0.0 API_HOST=0.0.0.0 VITE_HOST=0.0.0.0 API_BACKEND_URL=http://127.0.0.1:3001 sh -c 'bun --bun src/server/api.ts & api_pid=$!; trap \"kill $api_pid 2>/dev/null\" EXIT INT TERM; bun --bun vite dev --host 0.0.0.0'",
		"dev:web": "API_BACKEND_URL=http://localhost:3001 bun --bun vite dev",
		"dev:api": "bun --bun src/server/api.ts",
		"start:web": "bun ./build/index.js",
		"start:api": "bun --bun src/server/api.ts",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.2",
		"bun-types": "^1.3.14",
		"dotenv": "^17.4.2",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@fontsource/noto-sans": "^5.2.10",
		"@types/bun": "^1.3.14",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.25",
		"lucide-svelte": "^1.0.1",
		"vk-io": "^4.10.1"
	}
}
